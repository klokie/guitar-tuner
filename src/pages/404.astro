---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout title="Page not found">
  <section class="container">
    <h1>404 — that page doesn't exist</h1>
    <p>
      Maybe you were looking for the
      <a href="/">standard guitar tuner</a>, the
      <a href="/drop-d">Drop D tuner</a>, or the
      <a href="/half-step-down">half step down tuner</a>?
    </p>
  </section>
</SiteLayout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px;
    text-align: center;
  }
</style>
