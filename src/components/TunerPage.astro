---
/**
 * Shared shell for every tuning page: SEO wiring + tuner island + copy slot.
 * Pages differ only in tuning data and copy — adding a guitar-family tuning
 * is a tunings.ts entry plus one thin page.
 */
import SiteLayout from "@/layouts/SiteLayout.astro";
import Tuner from "@/components/Tuner.astro";
import { siteConfig } from "@/site/config";
import { TUNINGS, tuningPath } from "@/lib/tunings";

interface Props {
  title: string;
  description: string;
  heading: string;
  tuningSlug: string;
}
const { title, description, heading, tuningSlug } = Astro.props;
const tuning = TUNINGS[tuningSlug]!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: title,
  url: new URL(Astro.url.pathname, siteConfig.url).href,
  description,
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "Any",
  browserRequirements: "Requires a microphone for live tuning",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<SiteLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="container">
    <h1>{heading}</h1>
    <p class="strings-line">
      {tuning.strings.map((s) => s.note.replace(/\d+$/, "")).join(" – ")}
    </p>

    <Tuner tuningSlug={tuningSlug} />

    <section class="copy">
      <slot />
    </section>

    <nav class="other-tunings" aria-label="Other tunings">
      <h2>Other tunings</h2>
      <ul>
        {Object.values(TUNINGS)
          .filter((t) => t.slug !== tuningSlug)
          .map((t) => (
            <li><a href={tuningPath(t.slug)}>{t.name}</a></li>
          ))}
      </ul>
    </nav>
  </article>
</SiteLayout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    margin-bottom: 0.25rem;
    text-align: center;
  }
  .strings-line {
    text-align: center;
    opacity: 0.7;
    margin-bottom: 2rem;
    letter-spacing: 0.2em;
  }
  .copy {
    margin-top: 3rem;
  }
  .copy :global(h2) {
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin: 1.5rem 0 0.5rem;
  }
  .copy :global(p) {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }
  .other-tunings {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, currentColor 20%, transparent);
  }
  .other-tunings h2 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .other-tunings ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
</style>
