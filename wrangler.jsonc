{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "guitar-tuner",
  "compatibility_date": "2026-01-15",
  "workers_dev": false,
  "routes": [{ "pattern": "tuner.klokie.com", "custom_domain": true }],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
